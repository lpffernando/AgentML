# AutoML-Agent OpenCode Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# LLM Provider API Keys
# ===========================================

# OpenAI (optional)
# OPENAI_API_KEY=sk-...

# Anthropic (optional)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional)
# GEMINI_API_KEY=...

# Local models via vLLM (optional)
# VLLM_API_BASE=http://localhost:8000/v1
# VLLM_API_KEY=EMPTY

# ===========================================
# Database Configuration (optional)
# ===========================================

# PostgreSQL
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=automl
# POSTGRES_PASSWORD=...
# POSTGRES_DB=automl

# ===========================================
# MLflow Configuration (optional)
# ===========================================

# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=automl_experiment

# ===========================================
# Application Settings
# ===========================================

# Workspace directory for artifacts
WORKSPACE=./workspace

# Default timeout for code execution (seconds)
EXECUTION_TIMEOUT=120

# Number of parallel trials for hyperparameter tuning
NUM_TRIALS=100

# Cross-validation folds
CV_FOLDS=5

# ===========================================
# OpenCode Settings (optional)
# ===========================================

# OpenCode configuration
# OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514
# OPENCODE_TEMPERATURE=0.3
